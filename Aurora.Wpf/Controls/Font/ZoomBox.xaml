<controls:ZoomUserControl x:Class="Aurora.Wpf.Controls.Font.ZoomBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aurora.Wpf.Controls.Font"
             xmlns:controls="clr-namespace:Aurora.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <controls:ZoomUserControl.Resources>
        <CollectionViewSource Source="{Binding Source={x:Static Fonts.SystemFontFamilies}}" x:Key="familyCollection"/>
    </controls:ZoomUserControl.Resources>
    <StackPanel DataContext="{StaticResource familyCollection}">
        <TextBox FontSize="{Binding Value, ElementName=fontSizeSlider}" AcceptsReturn="true" 
            FontFamily="{Binding Source, Source={StaticResource familyCollection}}" 
            FontWeight="{Binding SelectedItem.Weight, ElementName=familyTypefacesList}" 
            FontStretch="{Binding SelectedItem.Stretch, ElementName=familyTypefacesList}" 
            FontStyle="{Binding SelectedItem.Style, ElementName=familyTypefacesList}" 
            TextAlignment="Center" TextWrapping="Wrap" Text="The quick brown fox jumps over the lazy dog"/>

    </StackPanel>
</controls:ZoomUserControl>
